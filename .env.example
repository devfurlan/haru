# .env da RAIZ - lido pelo CLI do Supabase (`npx supabase start`), que substitui as
# referências `env(...)` do supabase/config.toml. NÃO é usado pelos apps (web/mobile/bot
# têm seus próprios .env). Copie para `.env` na raiz e preencha os valores reais.
#
# Só é necessário para o Supabase LOCAL. Em produção o Supabase é hospedado e NÃO lê
# este arquivo: configure os mesmos valores no dashboard (Auth → Providers).

# Login com Google (área do cliente: web /conta e app mobile). Credenciais de um
# OAuth Client tipo "Web" no Google Cloud. Depois de setar, rode `pnpm supabase:reset`.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Opcional: assistente de IA do Supabase Studio local (env(OPENAI_API_KEY) no config.toml).
# Deixe vazio se não usar - não afeta o resto.
OPENAI_API_KEY=
