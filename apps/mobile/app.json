{
  "expo": {
    "name": "Demandaê",
    "slug": "demandae",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7010f884-2a4f-4aad-892e-f2a5fbe8aa11"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "demandae",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.demandae.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a3324",
          "image": "./assets/images/splash-seal.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localização para mostrar os estabelecimentos mais próximos de você."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Usamos suas fotos para você definir a foto de perfil."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7010f884-2a4f-4aad-892e-f2a5fbe8aa11"
      }
    }
  }
}
