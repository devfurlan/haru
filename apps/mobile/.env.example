# Variáveis do app mobile (Expo). Prefixo EXPO_PUBLIC_ = embutidas no bundle (públicas).
# Copie para .env e preencha. Nunca coloque segredos aqui (a chave publishable é pública por design).

# URL do Supabase (mesma do web). Em dev local: http://127.0.0.1:54361
EXPO_PUBLIC_SUPABASE_URL=

# Chave publishable/anon do Supabase (a mesma NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY do web)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Base URL da API (o app web que expõe /api/mobile/v1/*).
# Emulador Android: use http://10.0.2.2:4361 (o host aparece nesse IP dentro do emulador).
# Dispositivo físico: http://<IP-da-sua-maquina-na-LAN>:4361
EXPO_PUBLIC_API_URL=http://10.0.2.2:4361
