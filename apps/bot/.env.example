# Copie para .env — `pnpm --filter bot dev` lê via `tsx --env-file=.env`.
# Valores abaixo são os defaults do Supabase local rodando via `pnpm supabase:start` na raiz.

# Postgres local
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54362/postgres"

# Supabase (admin — bot precisa do service_role pra Storage etc.)
SUPABASE_URL="http://127.0.0.1:54361"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"

# WhatsApp Cloud API (Meta)
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
# Token "system user" da plataforma — capaz de operar todos os phone_number_ids
# onboarded via Embedded Signup. Em produção, tokens per-tenant ficam no DB.
WHATSAPP_PLATFORM_ACCESS_TOKEN=""

# Redis (Upstash) — estado da conversa + buffer do debouncer
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OpenAI
OPENAI_API_KEY=""

# Comunicação interna web ↔ bot
BOT_INTERNAL_TOKEN=""

# Observabilidade (opcional)
SENTRY_DSN=""
SENTRY_ENV=""
HEALTHCHECKS_URL=""

# Serviço
PORT="3001"
WEB_URL="http://localhost:4361"
