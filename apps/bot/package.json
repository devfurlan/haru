{
  "name": "bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "tunnel": "npx ngrok@latest http 3001",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@haru/billing": "workspace:*",
    "@haru/database": "workspace:*",
    "@haru/payments": "workspace:*",
    "@sentry/node": "^10.48.0",
    "@supabase/supabase-js": "^2.78.0",
    "@upstash/redis": "^1.34.3",
    "fastify": "^5.3.3",
    "openai": "^4.95.0"
  },
  "devDependencies": {
    "@haru/eslint-config": "workspace:*",
    "@haru/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
