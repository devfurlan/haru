# Copie para .env.local - Next.js lê automaticamente em dev.
# Valores abaixo são os defaults do Supabase local rodando via `pnpm supabase:start` na raiz.

# Postgres local (via @haru/database / Prisma adapter)
# Em produção: DATABASE_URL = transaction pooler (6543, ?pgbouncer=true).
# O `vercel-build` roda `prisma migrate deploy`, que usa DIRECT_URL = session pooler (5432).
# Garanta que AMBAS estejam disponíveis no passo de Build do Vercel.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54362/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54362/postgres"

# Supabase Auth (cliente browser + SSR)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54361"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

# Comunicação interna web ↔ bot (mesmo valor do apps/bot/.env)
BOT_INTERNAL_TOKEN=""
# URL base do bot - o web chama /internal/payment-confirmed pra avisar o cliente no
# WhatsApp quando o pagamento confirma. Dev: http://localhost:3001; prod: URL do Railway.
BOT_INTERNAL_URL="http://localhost:3001"

# Criptografia das credenciais de gateways de pagamento (AES-256-GCM).
# Obrigatória para a feature de pagamentos. 32 bytes - gere com: openssl rand -hex 32
# Cadastre o mesmo valor na Vercel (Production/Preview). NÃO comite o valor real.
PAYMENTS_ENCRYPTION_KEY=""

# Asaas da PLATAFORMA - cobrança da ASSINATURA do SaaS (recorrência). Diferente das
# credenciais por-tenant acima (tenant cobrando os clientes dele). É a chave única da
# NOSSA conta Asaas. O webhook de billing (/api/webhooks/billing/asaas) valida o header
# `asaas-access-token` contra ASAAS_PLATFORM_WEBHOOK_TOKEN (cadastre o mesmo valor no
# painel do Asaas ao criar o webhook).
# OBRIGATÓRIO em produção: o webhook de billing é fail-closed - se este token estiver
# vazio/ausente, TODO callback do Asaas é recusado (401) e a assinatura nunca ativa/renova.
ASAAS_PLATFORM_API_KEY=""
ASAAS_PLATFORM_SANDBOX="true"
ASAAS_PLATFORM_WEBHOOK_TOKEN=""

# Nota fiscal (NFS-e) da assinatura, emitida pelo Asaas a cada cobrança confirmada. Requer
# antes as "Configurações Fiscais" ATIVAS no painel do Asaas (inscrição municipal + certificado
# + serviço municipal) - trabalho de painel, não de código. Enquanto ASAAS_NF_SERVICE_DESCRIPTION
# e um dos serviços municipais (_ID ou _CODE) estiverem vazios, o gancho de NF fica em
# modo-marcador (não chama o Asaas). Ligue os eventos INVOICE_* no MESMO webhook de billing.
# Impostos: default 0 e ISS não retido (caso comum de emissor no Simples Nacional); ajuste
# conforme o seu regime.
ASAAS_NF_SERVICE_DESCRIPTION=""
# Envie UM dos dois: _ID quando a prefeitura tem lista de serviços; senão _CODE.
ASAAS_NF_MUNICIPAL_SERVICE_ID=""
ASAAS_NF_MUNICIPAL_SERVICE_CODE=""
ASAAS_NF_MUNICIPAL_SERVICE_NAME=""
ASAAS_NF_OBSERVATIONS=""
ASAAS_NF_RETAIN_ISS="false"
ASAAS_NF_TAX_ISS="0"
ASAAS_NF_TAX_COFINS="0"
ASAAS_NF_TAX_CSLL="0"
ASAAS_NF_TAX_INSS="0"
ASAAS_NF_TAX_IR="0"
ASAAS_NF_TAX_PIS="0"

# E-mails transacionais de billing (Resend). Avisam o DONO do tenant sobre falha de
# pagamento, ativação e suspensão da assinatura. Sem estas envs, o envio vira no-op.
# APP_URL = base pública do painel, usada nos links dos e-mails (ex.: https://app.demandae.com.br).
RESEND_API_KEY=""
BILLING_EMAIL_FROM="Demandaê <noreply@demandae.app>"
APP_URL="http://localhost:4361"

# Bot de suporte in-app (painel web + app mobile). Usa a OpenAI Responses API (gpt-5-mini)
# via fetch - sem SDK. Reaproveita OPENAI_API_KEY (a mesma do bot; também no .env raiz).
# Sem a chave, o chat responde com uma mensagem de fallback. Feedback (crítica/sugestão)
# é enviado por e-mail (Resend, mesmo FROM do billing) para SUPPORT_INBOX_EMAIL.
OPENAI_API_KEY=""
SUPPORT_INBOX_EMAIL="contato@demandae.com"

# WhatsApp Embedded Signup (onboarding automático via Meta).
# App ID e config_id NÃO são secretos - vão pro browser (prefixo NEXT_PUBLIC).
# - App ID: painel da Meta > Configurações do app > Básico (também aparece na URL do app).
# - config_id: Login do Facebook para empresas > Configurações (variação General +
#   permissões whatsapp_business_management/whatsapp_business_messaging). Um único
#   config_id serve pros dois fluxos (coexistence e número novo) - a diferença é
#   resolvida em runtime pelo featureType.
NEXT_PUBLIC_FACEBOOK_APP_ID=""
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=""
# Secret do app da Meta (server-only) - usado pra trocar o `code` do Embedded Signup
# por um access_token. Painel > Configurações > Básico > "Mostrar". NUNCA expor no
# browser nem commitar o valor real.
FACEBOOK_APP_SECRET=""

# Rate-limit dos endpoints públicos do app mobile (pay/bookings/slots, sem Bearer).
# MESMO Upstash Redis do bot (copie os valores de apps/bot/.env). Cadastre também na
# Vercel (Production/Preview). Sem estas envs o rate-limit vira no-op (fail-open) - o
# app funciona, só não protege contra abuso.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Verificação de telefone por SMS (Twilio Verify) - OTP exigido no cadastro do CLIENTE
# final. É o que torna seguro o "claim" do histórico por telefone (sem isso, alguém
# reivindicaria os agendamentos de outro número). Sem estas envs, o cadastro do cliente
# não consegue enviar/validar o código.
# - Account SID + Auth Token: home do Console da Twilio.
# - Verify Service SID (VA...): crie em Verify > Services no Console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
