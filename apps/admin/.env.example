# Banco (mesmo do web/bot - Prisma acessa cross-tenant, sem RLS).
DATABASE_URL=
DIRECT_URL=

# Supabase Auth (mesmo projeto do web). Admin = usuário com `app_metadata.is_admin = true`
# (definido pelo servidor, não pelo usuário). Não há allowlist em env.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
