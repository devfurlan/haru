# Banco (mesmo do web/bot - Prisma acessa cross-tenant, sem RLS).
DATABASE_URL=
DIRECT_URL=

# Supabase Auth (mesmo projeto do web). O admin loga com um usuário do Auth
# cujo e-mail esteja na allowlist abaixo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Allowlist de operadores: e-mails separados por vírgula. Só estes entram no painel.
# Ex.: ADMIN_EMAILS="13furlan@gmail.com,outro@operador.com"
ADMIN_EMAILS=
