{
  "name": "@haru/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsx check.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@haru/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
