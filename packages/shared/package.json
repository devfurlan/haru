{
  "name": "@haru/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsx check.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@haru/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
