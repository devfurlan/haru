generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Domain models (esqueleto inicial - expandir conforme o produto evolui) ---

model Tenant {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  /// Fuso usado pra interpretar horários do estabelecimento (ex: "America/Sao_Paulo").
  timezone String @default("America/Sao_Paulo")

  /// URL pública da logo do estabelecimento (bucket tenant-assets). Imagem
  /// quadrada padronizada - usada na página pública e no painel.
  logoUrl       String?
  /// Endereço físico exibido pro cliente (texto livre, opcional).
  address       String?
  /// Coordenadas geocodificadas do `address` (via Nominatim/OSM ao salvar no painel).
  /// Alimentam a busca por proximidade no app. null = sem endereço ou não geocodificável.
  latitude      Float?
  longitude     Float?
  /// Descrição do negócio (perfil comercial do WhatsApp `description`, máx 256).
  description   String?
  /// Status/recado curto do WhatsApp (`about`, máx 139). Específico do perfil WhatsApp.
  whatsappAbout String?
  /// E-mail de contato exibido no perfil comercial do WhatsApp (`email`).
  email         String?

  /// Agendamento direto pela página pública (/[slug]). Quando false, a página só
  /// mostra serviços/horários e o botão de WhatsApp (sem formulário de booking).
  publicBookingEnabled      Boolean                   @default(true)
  /// Status com que um agendamento feito pela página pública entra: PENDING exige
  /// o dono confirmar no painel; CONFIRMED já reserva o horário na hora.
  publicBookingConfirmation PublicBookingConfirmation @default(PENDING)

  // --- Vitrine / página pública -----------------------------------------------
  /// Segmento/tipo de negócio (ex.: "barbearia", "salão", "clínica"). Coletado no
  /// onboarding via chips; usado na vitrine e como meta da página. Texto livre.
  segment        String?
  /// "Sobre nós" da vitrine - texto mais longo/editorial que `description` (que é a
  /// bio de 256 do perfil WhatsApp). Exibido na página pública e no app.
  about          String?
  /// Comodidades do estabelecimento (chaves: estacionamento, wifi, acessivel,
  /// pix_cartao, ar, cafe, kids). Renderizadas como selos na vitrine.
  amenities      String[] @default([])
  /// Handle do Instagram (sem @) exibido nos contatos da página pública. Texto livre.
  instagram      String?
  /// Fotos de capa da vitrine (URLs no bucket tenant-assets), até 5. O índice 0 é a
  /// principal (★) e define a ordem do carrossel na página e no app.
  coverImageUrls String[] @default([])
  /// Avaliação média (1-5) e nº de avaliações - DENORMALIZADOS de Review, recomputados
  /// na mesma transação da escrita (ver lib/reviews.ts). Deixam os cards do diretório
  /// baratos (sem agregar por tenant). null/0 = ainda sem avaliação.
  ratingAvg      Float?
  ratingCount    Int      @default(0)

  /// Marca a conclusão do onboarding do dono (wizard de 4 passos). null = ainda não
  /// concluiu → o painel redireciona pra /onboarding. Tenants criados antes desta
  /// coluna recebem now() no backfill da migration (não veem o wizard).
  onboardingCompletedAt DateTime?

  // WhatsApp Cloud API - credenciais por tenant (onboard via Embedded Signup).
  // O bot resolve qual tenant atende um webhook por whatsappPhoneNumberId.
  whatsappPhoneNumberId     String?   @unique
  whatsappBusinessAccountId String?
  /// Token de acesso do tenant (criptografar at rest em produção).
  whatsappAccessToken       String?
  /// Telefone E.164 do WhatsApp (sem +) usado em links públicos wa.me/...
  /// É diferente do whatsappPhoneNumberId (ID interno da Meta).
  whatsappDisplayPhone      String?
  /// Marca quando o número foi detectado como BANIDO pela Meta (status do phone
  /// number = BANNED). Enquanto setado, o loop de lembretes pula o tenant - a
  /// Meta recusa todo envio com erro genérico (#135000), então re-tentar só gera
  /// ruído. O alerta por e-mail é disparado uma única vez na transição p/ banido.
  /// Volta a null quando o número for reabilitado (limpar manualmente após appeal).
  whatsappBannedAt          DateTime?
  /// Última quality_rating conhecida do número na Meta (GREEN/YELLOW/RED). O loop
  /// de qualidade compara contra este valor e só alerta o operador quando piora
  /// (transição de rating), sem floodar a cada poll.
  whatsappQualityRating     String?

  /// URL opcional para POST quando agendamentos são criados/cancelados. Aceita
  /// webhooks de Discord, Slack, Zapier, n8n, etc. Para Discord: o body inclui
  /// um campo `content` com o resumo formatado.
  notificationWebhookUrl        String?
  /// Horas antes do horário marcado para o bot enviar lembrete via WhatsApp.
  /// 0 = lembretes desativados.
  reminderMinutesBefore         Int     @default(30)
  /// Avisar o dono por e-mail quando um cliente pedir atendimento humano
  /// (handoff). O aviso no painel/realtime é sempre enviado; só o e-mail é opcional.
  handoffEmailEnabled           Boolean @default(true)
  /// Avisar o dono por e-mail dos eventos de agendamento: novo agendamento e quando
  /// o cliente cancela/remarca. NÃO inclui lembrete por agendamento (evita flood em
  /// agenda cheia). Controlado pelo dono em /settings; não afeta os e-mails do cliente.
  ownerAppointmentEmailsEnabled Boolean @default(true)
  /// Opt-in do dono a receber alertas (uso/cobrança) por WhatsApp, enviados pelo número
  /// da PLATAFORMA Demandaê (nunca pelo número do bot do tenant). Default off - só envia
  /// se ligado E o OWNER tiver telefone. O e-mail é sempre enviado; o WhatsApp é reforço.
  ownerWhatsappAlertsEnabled    Boolean @default(false)
  /// Templates aprovados na Meta. Quando definidos, mensagens são enviadas via
  /// template em vez de freeform - escapam da regra das 24h. Todos esperam
  /// 3 variáveis no body: {{1}}=nome do cliente, {{2}}=data/hora formatada,
  /// {{3}}=nome do serviço.
  reminderTemplateName          String?
  reminderTemplateLanguage      String? @default("pt_BR")
  cancelTemplateName            String?
  cancelTemplateLanguage        String? @default("pt_BR")
  rescheduleTemplateName        String?
  rescheduleTemplateLanguage    String? @default("pt_BR")
  /// Template aprovado na Meta usado no convite de novos usuários da equipe.
  /// Quando definido, o convite é enviado via template (escapa a janela de 24h).
  /// Espera 2 variáveis no body: {{1}}=nome do estabelecimento, {{2}}=link de ativação.
  inviteTemplateName            String?
  inviteTemplateLanguage        String? @default("pt_BR")

  // --- Fila de espera ---------------------------------------------------------
  /// Liga/desliga a fila de espera do estabelecimento (dono controla em /settings).
  /// Quando false, não dá pra entrar na fila e cancelamentos não disparam match.
  waitlistEnabled         Boolean @default(true)
  /// Minutos que cada onda tem pra confirmar antes de passar pra próxima (e por quanto
  /// tempo a reserva temporária segura os horários). Padrão 15.
  waitlistWindowMinutes   Int     @default(15)
  /// Modo de notificação: false = em ondas de 3 (padrão); true = avisa todos de uma vez.
  waitlistNotifyAllAtOnce Boolean @default(false)

  // --- Atendente IA (addon) ---------------------------------------------------
  /// Identidade que o Atendente IA usa pra se apresentar ao cliente final. Coletada
  /// na ativação do addon. Crítico na variante "número Demandaê" (número compartilhado):
  /// o bot precisa dizer de qual estabelecimento fala. Consumo destes campos é feito no
  /// pipeline do bot (fora do escopo desta camada, que só persiste).
  /// Nome exibido pelo bot (ex.: "Barbearia do Téo"). null = usa `name`.
  botDisplayName String?
  /// Tom de voz desejado (texto livre, ex.: "descontraído e direto"). null = padrão.
  botTone        String?
  /// Saudação de abertura personalizada. null = o bot usa a saudação padrão.
  botGreeting    String?

  // --- Pagamentos -------------------------------------------------------------
  /// Gateway de pagamento ativo. null = pagamentos desativados (sem botão "Pagar"
  /// na página pública). Só a credencial do provider ativo é usada.
  paymentProvider PaymentProvider?
  /// Quando true, usa as URLs de sandbox do gateway (testes). false = produção.
  paymentSandbox  Boolean          @default(false)

  /// Credenciais criptografadas at rest (AES-256-GCM, formato "iv:tag:ct" em base64).
  /// Um campo por gateway - só o do provider ativo é preenchido por vez.
  paymentAsaasApiKeyEnc      String?
  paymentMercadoPagoTokenEnc String?
  paymentPagBankTokenEnc     String?
  paymentPagarmeApiKeyEnc    String?
  /// Token compartilhado validado no header do webhook do gateway (Asaas:
  /// "asaas-access-token"). Criptografado igual às credenciais.
  paymentWebhookTokenEnc     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  services           Service[]
  appointments       Appointment[]
  appointmentSeries  AppointmentSeries[]
  contacts           Contact[]
  conversations      Conversation[]
  scheduleBlocks     ScheduleBlock[]
  scheduleExceptions ScheduleException[]
  payments           Payment[]
  aiUsageLogs        AiUsageLog[]
  favorites          Favorite[]
  reviews            Review[]
  subscription       Subscription?
  usageAlerts        UsageAlert[]
  notifications      Notification[]
  loyaltyProgram     LoyaltyProgram?
  waitlistEntries    WaitlistEntry[]
  waitlistOffers     WaitlistOffer[]
  membershipPlans    MembershipPlan[]
  memberships        Membership[]
  membershipCharges  MembershipCharge[]
}

model User {
  id              String     @id @default(cuid())
  // Vinculado ao auth.users do Supabase
  authId          String     @unique
  email           String     @unique
  name            String?
  /// Telefone E.164 sem máscara (ex.: "5511912345678"). Destino do convite por
  /// WhatsApp. Opcional - OWNER criado no signup não tem telefone.
  phone           String?
  role            UserRole   @default(OWNER)
  /// Foto de perfil (bucket tenant-assets). Já redimensionada (quadrada, 128px webp);
  /// null = usa a inicial do nome como avatar. Trocar apaga o arquivo antigo.
  avatarUrl       String?
  /// Profissional = tem agenda própria (horários, serviços) e recebe agendamentos.
  /// false = usuário de apoio (recepcionista/secretária): acessa e gerencia as
  /// agendas dos outros, mas não tem agenda própria nem aparece no booking.
  /// O OWNER nasce profissional (caso solo). Conta no limite do plano por categoria.
  isProfessional  Boolean    @default(false)
  /// Ciclo de vida do acesso. Membro convidado nasce INVITED (sem senha) e vira
  /// ACTIVE quando define a senha pela tela de ativação.
  status          UserStatus @default(ACTIVE)
  /// Quando o convite foi enviado (membros INVITED). Null pra quem nasceu ACTIVE.
  invitedAt       DateTime?
  /// Quando o usuário ativou a conta (definiu a senha).
  activatedAt     DateTime?
  /// Prova de consentimento: quando o usuário aceitou os Termos/Privacidade no
  /// cadastro. Null para contas anteriores ao aceite obrigatório.
  termsAcceptedAt DateTime?
  /// Versão dos Termos aceita (ver TERMS_VERSION em apps/web/src/lib/legal.ts).
  termsVersion    String?
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  conversationReads    ConversationRead[]
  handoffConversations Conversation[]        @relation("ConversationHandoff")
  /// Agenda própria do profissional (vazia para recepcionistas).
  scheduleBlocks       ScheduleBlock[]
  scheduleExceptions   ScheduleException[]
  appointments         Appointment[]
  professionalServices ProfessionalService[]
  waitlistEntries      WaitlistEntry[]
  waitlistOffers       WaitlistOffer[]
}

enum UserRole {
  OWNER
  STAFF
}

enum UserStatus {
  /// Convidado pelo admin, ainda não definiu a senha.
  INVITED
  /// Conta ativa (definiu a senha / criada no signup).
  ACTIVE
}

/// Identidade GLOBAL do cliente final (quem agenda serviços), com login próprio.
/// Diferente de `User` (dono/staff): uma CustomerAccount é cross-tenant - enxerga os
/// agendamentos de TODOS os estabelecimentos onde o cliente agendou. Vinculada ao
/// auth.users do Supabase pelo authId (mesma tabela de auth dos donos, tabelas de
/// domínio distintas). O vínculo com os Contacts (um por tenant) é feito por
/// telefone - ver claimContactsByPhone em apps/web/src/lib/customer-claim.ts.
model CustomerAccount {
  id                       String    @id @default(cuid())
  /// Vinculado ao auth.users do Supabase (mesma origem que User.authId).
  authId                   String    @unique
  email                    String    @unique
  name                     String?
  /// Foto de perfil (bucket tenant-assets). Já redimensionada (quadrada, 128px);
  /// null = usa a inicial do nome como avatar. Trocar apaga o arquivo antigo.
  avatarUrl                String?
  /// Telefone E.164 sem máscara (ex.: "5511912345678") - SÓ recebe número já
  /// VERIFICADO por OTP. É o que reivindica (claim) os Contacts de mesmo telefone em
  /// todos os tenants. Opcional: a conta pode existir antes de confirmar o telefone.
  phone                    String?
  /// Telefone informado no cadastro mas AINDA NÃO verificado. Fica separado de
  /// `phone` pra nunca disparar o claim sem prova de posse; serve só pra pré-preencher
  /// a barra de confirmação pós-login. É limpo quando o número é confirmado.
  pendingPhone             String?
  /// CPF/CNPJ (só dígitos, criptografado com encryptSecret) informado pelo cliente no
  /// próprio cadastro - prefixa o checkout ("não pedimos de novo"). Vive na conta (não
  /// só nos Contacts por-tenant) pra sobreviver quando ainda não há nenhum agendamento.
  document                 String?
  /// Data de nascimento (meia-noite UTC) informada no cadastro. Mesmo motivo do document.
  birthDate                DateTime?
  /// Prova de consentimento (Termos/Privacidade) no cadastro do cliente.
  termsAcceptedAt          DateTime?
  /// Versão dos Termos aceita (ver TERMS_VERSION em apps/web/src/lib/legal.ts).
  termsVersion             String?
  /// Receber e-mails dos próprios agendamentos (confirmação, lembrete, remarcação,
  /// cancelamento). Controlado pelo cliente em /conta/perfil. Independente dos avisos
  /// por WhatsApp do estabelecimento.
  appointmentEmailsEnabled Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  contacts    Contact[]
  pushDevices PushDevice[]
  favorites   Favorite[]
  reviews     Review[]
  memberships Membership[]

  @@index([phone])
}

/// Estabelecimento favoritado por um cliente (cross-tenant). Só aparece no app do
/// cliente; um par (cliente, tenant) é único (favoritar de novo é idempotente).
model Favorite {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([customerAccountId, tenantId])
  @@index([customerAccountId])
  @@index([tenantId])
}

/// Avaliação (1-5 estrelas + comentário opcional) de um cliente a um estabelecimento.
/// Cross-tenant, um par (cliente, tenant) é único - reavaliar EDITA a nota (upsert). Só
/// avalia quem teve um Appointment COMPLETED no tenant (gate em lib/reviews.ts:canReview).
/// A média/contagem ficam denormalizadas em Tenant.ratingAvg/ratingCount, recomputadas na
/// mesma transação da escrita.
model Review {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Nota de 1 a 5 (validada na escrita).
  rating            Int
  comment           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([customerAccountId, tenantId])
  @@index([tenantId])
}

/// Dispositivo (app mobile) de um cliente para receber push (Expo Push). Um cliente
/// pode ter vários aparelhos. O token identifica o device na Expo; é substituível
/// (o app re-registra a cada login). Usado pelo loop de lembretes do bot.
model PushDevice {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  /// Expo push token (ex.: "ExponentPushToken[...]"). Único: um device = um token.
  expoPushToken     String          @unique
  /// "android" | "ios" (informativo).
  platform          String?
  createdAt         DateTime        @default(now())
  lastSeenAt        DateTime        @default(now())

  @@index([customerAccountId])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments       Appointment[]
  /// Quais profissionais executam este serviço (N:N). Vazio = nenhum oferece.
  professionals      ProfessionalService[]
  /// Programas de fidelidade que dão ESTE serviço como prêmio (prizeServiceId).
  loyaltyPrizeFor    LoyaltyProgram[]
  /// Programas em que ESTE serviço conta carimbo (quando countMode = SPECIFIC).
  loyaltyQualifiesIn LoyaltyProgramService[]
  waitlistEntries    WaitlistEntry[]
  membershipPlans    MembershipPlanService[]
}

/// Vínculo N:N entre um profissional (User) e um Service que ele executa. Define
/// quem pode ser agendado para cada serviço no booking público e no bot.
model ProfessionalService {
  id             String   @id @default(cuid())
  professionalId String
  professional   User     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([professionalId, serviceId])
  @@index([serviceId])
}

/// Janela de atendimento de um PROFISSIONAL em um dia da semana. Múltiplos blocos
/// no mesmo dia representam expediente partido (ex: 08:00-12:00 e 14:00-18:00).
/// Ausência de blocos para um weekday = profissional fechado naquele dia.
model ScheduleBlock {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Profissional dono desta grade (User com isProfessional=true).
  professionalId String
  professional   User     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  /// 0 = domingo, 6 = sábado (igual `Date#getDay()`).
  weekday        Int
  /// Minutos desde a meia-noite (ex: 480 = 08:00).
  startMinute    Int
  endMinute      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, professionalId, weekday])
}

/// Bloqueio pontual da agenda do Tenant: um intervalo [startsAt, endsAt) em UTC
/// onde não se aceita agendamento (folga, compromisso pessoal, férias).
/// "Dia inteiro" e "vários dias" são apenas intervalos maiores.
model ScheduleException {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Folga de um profissional específico. null = folga do estabelecimento inteiro
  /// (aplica a todos os profissionais).
  professionalId String?
  professional   User?    @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, startsAt])
}

model Contact {
  id                 String           @id @default(cuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Telefone E.164 (ex.: "5511912345678"). Opcional: cliente logado pode agendar sem
  /// WhatsApp (identidade vem da CustomerAccount). Com telefone, é a chave de dedup do
  /// contato por tenant (@@unique abaixo; múltiplos NULL são distintos no Postgres).
  phone              String?
  name               String?
  email              String?
  /// CPF/CNPJ do cliente, só dígitos (ex.: "12345678909"). Coletado no pagamento
  /// (o Asaas exige documento do pagador pra emitir Pix) e reusado em cobranças futuras.
  document           String?
  /// Data de nascimento. Guardada como meia-noite UTC; a parte de hora é ignorada.
  birthDate          DateTime?
  /// Marca quando o cliente confirmou o cadastro básico via bot. null = ainda não.
  /// É o sinal usado pelo gate de agendamento (NÃO confiar em `name`, que o profile do WhatsApp autopreenche).
  profileCompletedAt DateTime?
  /// Cliente pediu pra parar de receber lembretes por WhatsApp ("parar"/"sair").
  /// Enquanto setado, o loop de lembretes pula o envio WhatsApp deste contato (o
  /// e-mail tem opt-out próprio em CustomerAccount). Zerado só manualmente.
  remindersOptOutAt  DateTime?
  /// Conta global do cliente que reivindicou este Contact (por telefone). null =
  /// ainda não vinculado a um login. Um Contact pertence a um único tenant, mas
  /// vários Contacts (de tenants diferentes) podem apontar pra mesma CustomerAccount.
  /// onDelete: SetNull -> apagar a conta do cliente NÃO apaga o Contact (que é do tenant).
  customerAccountId  String?
  customerAccount    CustomerAccount? @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  conversations      Conversation[]
  appointments       Appointment[]
  loyaltyRedemptions LoyaltyRedemption[]
  waitlistEntries    WaitlistEntry[]
  memberships        Membership[]

  @@unique([tenantId, phone])
  @@index([customerAccountId])
  @@index([phone])
}

model Conversation {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId        String
  contact          Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// Handoff humano: enquanto > now(), o bot fica em silêncio nesta conversa e o
  /// dono responde manualmente pelo painel. null = bot ativo. Cada mensagem do
  /// cliente renova a janela (24h de inatividade); expira sozinho sem cron.
  handoffExpiresAt DateTime?
  /// Quem assumiu a conversa (atribuição "em atendimento por X"). null = bot ativo.
  handoffById      String?
  handoffBy        User?     @relation("ConversationHandoff", fields: [handoffById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages    Message[]
  reads       ConversationRead[]
  aiUsageLogs AiUsageLog[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  waMessageId    String?          @unique
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, direction, createdAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

/// Marca de leitura por usuário: cada usuário do tenant tem seu próprio estado
/// de "lida" por conversa. Conversa não-lida = existe Message INBOUND com
/// createdAt > lastReadAt (ou sem registro de leitura).
model ConversationRead {
  userId         String
  conversationId String
  lastReadAt     DateTime @default(now()) @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([conversationId])
}

model Appointment {
  id                  String             @id @default(cuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId           String
  contact             Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  serviceId           String
  service             Service            @relation(fields: [serviceId], references: [id])
  /// Profissional que atende este agendamento (User com isProfessional=true).
  professionalId      String
  professional        User               @relation(fields: [professionalId], references: [id])
  startsAt            DateTime
  endsAt              DateTime
  status              AppointmentStatus  @default(PENDING)
  /// Série de recorrência à qual essa ocorrência pertence. null = agendamento avulso.
  /// Ocorrências da mesma série compartilham serviço/contato e são geradas juntas.
  seriesId            String?
  series              AppointmentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  /// Marca de quando o lembrete via WhatsApp foi enviado. null = ainda não.
  reminderSentAt      DateTime?
  /// Marca de quando o lembrete por E-MAIL ao cliente foi processado. null = ainda
  /// não. Separado de `reminderSentAt` (WhatsApp) pra que os dois canais sejam
  /// independentes. Zerado junto na remarcação, pra disparar de novo no novo horário.
  reminderEmailSentAt DateTime?
  /// Marca de quando o lembrete via PUSH (app) foi enviado. null = ainda não. Mesmo
  /// padrão dos outros canais - evita reenvio a cada tick do loop; zerado na remarcação.
  reminderPushSentAt  DateTime?
  /// True quando este agendamento nasceu de uma confirmação na FILA DE ESPERA (vaga
  /// recuperada). Alimenta on-read a métrica de receita recuperada no painel do dono.
  fromWaitlist        Boolean            @default(false)
  /// Assinatura de serviços que cobriu este agendamento (crédito consumido). null =
  /// avulso (pago normal ou sem cobrança). A FONTE do débito é a linha REDEEM do
  /// MembershipCreditLedger com este appointmentId; este campo é o link barato pra
  /// leitura/estorno. onDelete: SetNull -> apagar a assinatura não apaga o histórico.
  membershipId        String?
  membership          Membership?        @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments     Payment[]
  creditLedger MembershipCreditLedger[]

  @@index([tenantId, startsAt])
  @@index([professionalId, startsAt])
  @@index([seriesId])
  @@index([membershipId])
}

/// Agrupa as ocorrências de um agendamento recorrente (semanal/quinzenal/mensal).
/// As ocorrências são expandidas em registros Appointment reais na criação - esta
/// tabela guarda só a regra (frequência), pra rotular a série e cancelá-la inteira.
model AppointmentSeries {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  frequency RecurrenceFrequency
  createdAt DateTime            @default(now())

  appointments Appointment[]

  @@index([tenantId])
}

/// Frequência de repetição de uma série de agendamentos.
enum RecurrenceFrequency {
  WEEKLY // toda semana (+7 dias)
  BIWEEKLY // quinzenal (+14 dias)
  MONTHLY // mensal (+1 mês, mesmo dia, com clamp ao último dia do mês)
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NO_SHOW
}

/// Status inicial de um agendamento feito pela página pública. Subconjunto de
/// AppointmentStatus (só os estados válidos na criação) - enum próprio pra impedir
/// gravar CANCELED/COMPLETED/NO_SHOW como default.
enum PublicBookingConfirmation {
  PENDING
  CONFIRMED
}

/// Cobrança de um agendamento via gateway de pagamento. Relação 1:N com Appointment
/// (re-tentativas geram registros novos preservando histórico); a "cobrança ativa" é
/// a PENDING mais recente não expirada. Pagamento é opcional e NÃO altera o status do
/// Appointment - confirmação de agenda e de pagamento são independentes.
model Payment {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  method   PaymentMethod   @default(UNDEFINED)
  status   PaymentStatus   @default(PENDING)

  /// Snapshot do Service.priceCents no momento da cobrança - o preço do serviço pode
  /// mudar depois; a cobrança preserva o valor cobrado de fato.
  amountCents Int

  /// CPF/CNPJ do pagador (só dígitos) enviado ao gateway nesta cobrança. Snapshot -
  /// o `Contact.document` pode mudar; aqui fica o documento usado de fato na charge.
  payerDocument String?

  /// ID da cobrança no gateway (ex.: Asaas "pay_xxx"). Único por provider.
  externalId   String?
  /// URL do checkout/fatura hospedada (Asaas invoiceUrl) - usada pra cartão e fallback.
  checkoutUrl  String?
  /// Pix: imagem do QR em base64 (data URI) e o copia-e-cola (payload EMV).
  pixQrCode    String?
  pixCopyPaste String?
  /// Vencimento da cobrança (Pix expira). Decide reaproveitar ou recriar a cobrança.
  expiresAt    DateTime?
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, externalId])
  @@index([tenantId, status])
  @@index([appointmentId])
}

/// Gateways de pagamento suportados. Só ASAAS está implementado; os demais têm
/// adapter stub (UI selecionável, cobrança lança "ainda não disponível").
enum PaymentProvider {
  ASAAS
  MERCADO_PAGO
  PAGBANK
  PAGARME
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  EXPIRED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  /// Checkout que deixa o cliente escolher o meio (Asaas billingType UNDEFINED).
  UNDEFINED
}

/// Pré-cadastro de interesse vindo da landing (signup público está desativado).
model Lead {
  id           String   @id @default(cuid())
  name         String
  businessName String
  whatsapp     String
  email        String?
  message      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// Consumo de tokens da OpenAI por tenant. Uma linha por turno do bot
/// (já agregando todas as chamadas do loop de tool calls). Usada para
/// medir/ratear o custo de IA de cada estabelecimento.
model AiUsageLog {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Conversa que originou o consumo (drill-down). null se a conversa sumiu.
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  /// Modelo usado (ex: "gpt-5-mini").
  model String

  /// Total de tokens de input do turno (inclui os cacheados).
  inputTokens       Int
  /// Subconjunto de `inputTokens` servido do cache (cobrado com desconto).
  cachedInputTokens Int @default(0)
  /// Tokens de output (inclui os de reasoning).
  outputTokens      Int
  /// Tokens de reasoning (subconjunto de `outputTokens`), só pra visibilidade.
  reasoningTokens   Int @default(0)
  /// Soma reportada pela OpenAI (input + output).
  totalTokens       Int
  /// Quantas chamadas à OpenAI compuseram o turno (1 + tool hops).
  requests          Int @default(1)

  /// Custo estimado em USD, calculado na escrita com o preço vigente do modelo
  /// (congela o preço da época, imune a mudanças futuras de tabela).
  costUsd Decimal @db.Decimal(12, 6)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// --- Billing / planos (assinatura do SaaS) -----------------------------------

/// Catálogo de planos editável (preço/limites/features mudam sem deploy). A
/// `Subscription` fotografa estes valores na ativação - mudar um Plan aqui só
/// afeta NOVOS assinantes e a página /precos; quem já assina mantém o snapshot.
model Plan {
  id   String   @id @default(cuid())
  tier PlanTier @unique
  name String

  /// Preços em centavos. priceAnnualCents = total do ciclo anual à vista (já com desconto).
  priceMonthlyCents           Int
  priceAnnualCents            Int
  /// Valor de CADA parcela no anual 12x (taxas de parcelamento repassadas ao cliente,
  /// logo 12x este valor > priceAnnualCents à vista). Ver BillingCycle.ANNUAL_INSTALLMENTS.
  priceAnnualInstallmentCents Int @default(0)

  /// Limites mensais. null = ilimitado (Enterprise).
  appointmentsPerMonth Int?
  /// @deprecated IA inbound saiu do plano base e virou addon (ver `AddonPlan` +
  /// `Subscription.addonConversationsLimit`). Mantido só p/ não quebrar telas antigas;
  /// remover quando a tela de billing for refeita. Seed novo grava null (base sem bot).
  aiMessagesPerMonth   Int?
  /// Máximo de profissionais (usuários com agenda própria). 1 = só o dono. null = ilimitado.
  maxProfessionals     Int?
  /// Máximo de recepcionistas (usuários de apoio, sem agenda). 0 = nenhum. null = ilimitado.
  maxReceptionists     Int?

  /// Features liberadas pelo tier.
  onlinePayments Boolean @default(false)
  webhooks       Boolean @default(false)
  team           Boolean @default(false)

  /// Disponível para contratação / visível na página de preços.
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Catálogo do addon "Atendente IA no WhatsApp" - bot conversacional inbound com
/// teto de conversas PRÓPRIO, INDEPENDENTE do plano base. Um Tenant pode ter plano
/// Solo com Bot Time ativo, por exemplo. Mesma lógica de grandfather do `Plan`: a
/// `Subscription` fotografa estes valores nas colunas `addon*` na ativação, e o
/// gating lê do snapshot, não daqui.
model AddonPlan {
  id   String    @id @default(cuid())
  tier AddonTier @unique
  name String

  priceMonthlyCents           Int
  /// Anual à vista / 12x do addon. 0 = não ofertado (o doc de pricing só definiu o
  /// mensal do addon; colunas prontas p/ quando os ciclos anuais forem precificados).
  priceAnnualCents            Int @default(0)
  priceAnnualInstallmentCents Int @default(0)
  /// Setup do addon (configuração da WABA). SEMPRE cobrado - nunca grátis, nem no
  /// anual, nem em promoção (paga trabalho real de WABA + config).
  setupFeeCents               Int

  /// Teto de conversas/mês do bot. null = ilimitado (fair use / Enterprise).
  conversationsPerMonth Int?

  active       Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Assinatura do SaaS de um Tenant (1:1). Guarda um SNAPSHOT dos termos do Plan
/// no momento da contratação - o gating lê daqui, não do Plan ao vivo, garantindo
/// que reprecificar um Plan não muda quem já assina (grandfather).
model Subscription {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planTier     PlanTier
  status       SubscriptionStatus @default(PENDING)
  billingCycle BillingCycle       @default(MONTHLY)

  /// Downgrade agendado: plano/ciclo a aplicar na PRÓXIMA renovação (nunca retroativo).
  /// Upgrade aplica na hora e limpa estes. O webhook de renovação lê estes campos, troca
  /// o snapshot pelo plano pendente e os zera. null = sem troca agendada.
  pendingPlanTier     PlanTier?
  pendingBillingCycle BillingCycle?

  /// Janela do ciclo atual de cobrança.
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  /// Prazo da garantia de satisfação (reembolso integral até esta data, ~30d).
  guaranteeUntil     DateTime?
  canceledAt         DateTime?
  /// Motivo opcional informado pelo dono ao cancelar (feedback). null = não informou.
  canceledReason     String?

  // --- Snapshot dos termos contratados (copiado do Plan na ativação) ---
  /// Preço efetivamente contratado, em centavos, referente ao billingCycle.
  priceCents         Int
  appointmentsLimit  Int?
  aiMessagesLimit    Int?
  maxProfessionals   Int?
  maxReceptionists   Int?
  featOnlinePayments Boolean @default(false)
  featWebhooks       Boolean @default(false)
  featTeam           Boolean @default(false)

  // --- Addon "Atendente IA no WhatsApp" (snapshot próprio, grandfather) ----------
  /// Tier do addon contratado. null = sem addon (só plano base). Independente do
  /// `planTier` (Solo base + Bot Time é válido). É setado já na ESCOLHA (antes de
  /// pagar/ativar) - por isso o gating de "addon ativo" olha `addonActivatedAt`, não isto.
  addonTier               AddonTier?
  /// Canal escolhido na ativação: número compartilhado do Demandaê (sem setup, ativa na
  /// hora) ou número próprio do estabelecimento (WABA + setup assistido). null = sem addon.
  addonChannel            AddonChannel?
  /// Ciclo do addon (pode diferir do ciclo base). null quando não há addon.
  addonBillingCycle       BillingCycle?
  /// Snapshot dos termos do addon na ativação (congela preço/teto - grandfather).
  addonPriceCents         Int?
  addonSetupFeeCents      Int?
  addonConversationsLimit Int?
  /// Setup do addon (R$1.497) já cobrado - sempre cobrado na ativação; guarda contra
  /// cobrança dupla. null = addon nunca ativado.
  addonSetupChargedAt     DateTime?
  addonActivatedAt        DateTime?
  addonCanceledAt         DateTime?

  // --- Asaas (recorrência - Fase 2) ---
  asaasCustomerId     String?
  asaasSubscriptionId String?
  /// Última cobrança do Asaas já contabilizada. Dedup de webhook: o Asaas manda
  /// CONFIRMED e RECEIVED para o mesmo pagamento - guardamos o id pra não enviar
  /// e-mail/recibo duplicado nem reprocessar.
  lastBilledPaymentId String?

  // --- Forma de pagamento da recorrência (escolhida em "Trocar forma de pagamento") ---
  /// Método ativo da recorrência (CREDIT_CARD | PIX). null = ainda não definido/legado.
  /// Reusa o enum PaymentMethod (UNDEFINED não se aplica à assinatura).
  paymentMethod  PaymentMethod?
  /// Últimos 4 dígitos e bandeira do cartão tokenizado - só p/ exibir "•••• 4242". O
  /// PAN/CVV NUNCA é persistido: é repassado ao Asaas e tokenizado.
  cardLast4      String?
  cardBrand      String?
  /// Token do cartão devolvido pelo Asaas (NÃO é dado de cartão). Permite recobrar/
  /// reativar sem redigitar. Guardado só quando o método é cartão.
  asaasCardToken String?
  /// id da autorização de Pix Automático (autoriza-uma-vez), quando a conta Asaas tem o
  /// recurso. null = Pix por ciclo (QR por cobrança) ou método não-Pix.
  pixRecurringId String?

  /// Marca quando o lembrete de renovação (7d antes) já saiu neste ciclo. Resetado a
  /// null na renovação (webhook ACTIVE) pra rearmar no ciclo seguinte. Dedup do cron.
  renewalReminderSentAt DateTime?

  /// Ledger local de cobranças desta assinatura (rastreabilidade: cada cobrança
  /// linkada ao plano/ciclo vigente no momento). Ver model Charge.
  charges Charge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// Dedup dos alertas de uso PUSH (email/WhatsApp): uma linha por (tenant, métrica,
/// janela de cota). `level` = maior nível já alertado nessa janela (85/90/95/100), pra
/// não repetir o mesmo alerta no mesmo ciclo nem alertar "pra trás". Nova janela de
/// cobrança = novo `windowStart` = linha nova = alertas zerados (reset por ciclo). O
/// banner in-app é status ao vivo e não passa por aqui. Ver @haru/billing nextUsageAlerts.
model UsageAlert {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// 'appointments' (plano base) | 'conversations' (addon) | 'fairuse' (alerta interno).
  metric      String
  /// Início da janela de cota (mensal, ancorada no dia do ciclo) a que o alerta pertence.
  windowStart DateTime
  /// Maior nível já alertado nesta janela: 85 | 90 | 95 | 100.
  level       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, metric, windowStart])
  @@index([tenantId])
}

/// Centro de notificações in-app (sino do painel). Uma linha por aviso destinado ao DONO
/// do estabelecimento. Dois canais: ACCOUNT (conta/uso/cobrança - acionável) e PRODUCT
/// (novidades do produto - broadcast, um fan-out por tenant). `kind` identifica o tipo
/// (ex.: "usage.appointments.90", "billing.past_due", "renewal.upcoming", "product.news")
/// e serve de dedup + ícone. Escrito pelo loop de uso (bot), pelo webhook de billing e
/// pelo cron de renovação. Ler = marcar readAt. Leitura por tenant (não por usuário).
model Notification {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  /// Tipo do aviso (dedup + ícone), ex.: "usage.appointments.90", "billing.past_due".
  kind      String
  title     String
  body      String
  /// CTA opcional: rótulo + destino relativo no app (ex.: "/assinatura").
  ctaLabel  String?
  ctaHref   String?
  /// null = não lida. Marcada quando o dono abre o sino.
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([tenantId, createdAt])
}

enum NotificationChannel {
  /// Conta: uso, cobrança, renovação. Acionável.
  ACCOUNT
  /// Novidades e updates de produto. Broadcast (canal separado).
  PRODUCT
}

enum PlanTier {
  ESSENCIAL
  PROFISSIONAL
  NEGOCIO
  ENTERPRISE
}

enum SubscriptionStatus {
  /// Aguardando confirmação do primeiro pagamento (Fase 2).
  PENDING
  /// Assinatura em dia.
  ACTIVE
  /// Pagamento falhou; em carência (grace) ainda com acesso.
  PAST_DUE
  /// Carência esgotada ou cancelada; sem acesso (bot off, dashboard read-only).
  SUSPENDED
  /// Cancelada pelo cliente ao fim do ciclo.
  CANCELED
}

enum BillingCycle {
  MONTHLY
  /// Anual à vista (10x o mensal - "2 meses grátis").
  ANNUAL
  /// Anual parcelado em 12x com taxas de parcelamento repassadas ao cliente.
  ANNUAL_INSTALLMENTS
}

/// Tiers do addon "Atendente IA no WhatsApp", com tetos de conversa próprios,
/// independentes do plano base. Rótulos amigáveis em ADDON_TIER_LABEL (@haru/billing).
enum AddonTier {
  BOT_SOLO
  BOT_TIME
  BOT_MULTI
}

/// Canal do addon "Atendente IA". DEMANDAE = bot no número compartilhado da plataforma
/// (se identifica como o estabelecimento; sem WABA, sem setup, ativa na hora). OWN =
/// número próprio do estabelecimento (WABA via Embedded Signup + setup R$1.497 assistido).
enum AddonChannel {
  DEMANDAE
  OWN
}

/// Ledger local de cobranças da assinatura do SaaS. Uma linha por pagamento no Asaas
/// (assinatura recorrente, parcelamento 12x, ou setup avulso do addon). Existe para
/// RASTREABILIDADE: cada cobrança carrega o plano/ciclo/valor vigentes no momento
/// (snapshot, não referência viva ao Plan), o vínculo com a Subscription, e o estado do
/// pagamento e da NF. O webhook do Asaas é o único escritor (idempotente por
/// asaasPaymentId). Ver apps/web .../api/webhooks/billing/asaas.
model Charge {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  /// id do pagamento no Asaas (payment.id). Unique = dedup natural do webhook
  /// (CONFIRMED e RECEIVED chegam para o mesmo pagamento).
  asaasPaymentId      String  @unique
  /// id da assinatura Asaas quando a cobrança é recorrente (mensal/anual à vista).
  /// null para 12x (installment avulso) e para o setup do addon.
  asaasSubscriptionId String?

  /// O que esta cobrança cobre (rastreabilidade dos componentes da fatura).
  kind         ChargeKind
  /// Snapshot do plano/ciclo/valor vigentes NO MOMENTO da cobrança (grandfather).
  planTier     PlanTier
  billingCycle BillingCycle
  amountCents  Int

  status     ChargeStatus @default(PENDING)
  dueDate    DateTime?
  paidAt     DateTime?
  refundedAt DateTime?

  /// Gancho fiscal: estado da emissão de NF desta cobrança e o custo (R$0,40/emissão)
  /// registrado para cálculo de margem. Integração NFS-e via Asaas (assíncrona: o gancho
  /// agenda/autoriza; o webhook INVOICE_* fecha o estado).
  nfStatus       NfStatus @default(NONE)
  /// Custo da emissão (R$0,40), gravado só quando a nota é AUTORIZADA de fato (é quando o
  /// Asaas cobra). Fica 0 se a emissão falhar. Alimenta o cálculo de margem.
  nfCostCents    Int      @default(0)
  /// id da nota no Asaas (invoice.id) - reconcilia o webhook INVOICE_* com esta cobrança.
  asaasInvoiceId String?  @unique
  /// Link do PDF da nota autorizada (enviado ao cliente por e-mail).
  nfUrl          String?
  /// Número fiscal da nota autorizada (recibo/rastreio).
  nfNumber       String?
  /// Última mensagem de erro de emissão (quando nfStatus=FAILED).
  nfError        String?
  /// Tentativas de emissão já feitas - teto de retentativa do cron, evita loop de erro.
  nfAttempts     Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([status])
}

enum ChargeKind {
  /// Mensalidade/anuidade do plano base.
  PLAN
  /// Só o addon "Atendente IA" (fatura própria).
  ADDON
  /// Plano base + addon somados na mesma fatura (mesmo ciclo).
  PLAN_ADDON
  /// Setup do addon (R$1.497), sempre cobrança avulsa no ato da ativação.
  SETUP
}

enum ChargeStatus {
  PENDING
  CONFIRMED
  OVERDUE
  REFUNDED
  CANCELED
}

enum NfStatus {
  /// Sem NF prevista para esta cobrança.
  NONE
  /// Emissão disparada (gancho), aguardando integração fiscal real.
  PENDING
  /// NF emitida (integração fiscal futura marca isto).
  ISSUED
  /// Falha na emissão.
  FAILED
}

// --- Suporte in-app (bot de IA que responde dúvidas e coleta feedback) --------
// Uma linha por mensagem (usuário ou assistente). O "histórico" de uma pessoa é o
// conjunto de linhas dela ordenado por createdAt - não há tabela de thread. Serve os
// dois apps: WEB (dono do negócio, via userId+tenantId) e MOBILE (cliente final, via
// customerAccountId). Quando a IA detecta crítica/sugestão, marca feedbackCategory e o
// servidor manda um e-mail; nada é respondido in-app pelo fundador.
// ponytail: FK solta (sem relation) pra migration mínima; virar relation quando
// precisar de join/cascade.
model SupportMessage {
  id      String         @id @default(cuid())
  channel SupportChannel
  role    SupportRole
  body    String

  /// WEB: User (dono/staff) que escreveu/recebeu. null no mobile.
  userId            String?
  /// WEB: tenant do usuário logado (contexto do negócio). null no mobile.
  tenantId          String?
  /// MOBILE: cliente final. null no web.
  customerAccountId String?

  /// Set só quando a mensagem do usuário foi classificada como feedback.
  feedbackCategory SupportCategory?
  /// MOBILE: quando o feedback é sobre um estabelecimento específico do cliente.
  aboutTenantId    String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([customerAccountId, createdAt])
}

enum SupportChannel {
  WEB
  MOBILE
}

enum SupportRole {
  USER
  ASSISTANT
}

enum SupportCategory {
  DUVIDA
  CRITICA
  SUGESTAO
}

/// Programa de fidelidade (cartão de carimbos) de um estabelecimento. Um por tenant.
/// Os CARIMBOS não são armazenados: derivam do histórico de agendamentos do cliente
/// (todo agendamento passado que não foi cancelado nem deu falta vale 1 carimbo,
/// espelhando a regra de `isReviewable`). O único estado gravado por cliente é o
/// RESGATE (LoyaltyRedemption), que zera o cartão a partir da data do resgate. Ver
/// apps/web/src/lib/loyalty.ts.
model LoyaltyProgram {
  id              String           @id @default(cuid())
  tenantId        String           @unique
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Quantos carimbos completam o cartão (fidN no protótipo). Entre 5 e 15.
  stampsRequired  Int              @default(10)
  /// FREE_SERVICE = um serviço de graça (prizeServiceId); DISCOUNT = desconto (discountPercent).
  prizeKind       LoyaltyPrizeKind @default(FREE_SERVICE)
  /// Serviço dado de graça quando prizeKind = FREE_SERVICE. onDelete: SetNull -> apagar
  /// o serviço não derruba o programa (a regra continua, só perde a referência do prêmio).
  prizeServiceId  String?
  prizeService    Service?         @relation(fields: [prizeServiceId], references: [id], onDelete: SetNull)
  /// Percentual de desconto (1-100) quando prizeKind = DISCOUNT.
  discountPercent Int?
  /// ALL_SERVICES = qualquer agendamento vale carimbo; SPECIFIC = só os serviços em
  /// qualifyingServices (fidConta no protótipo).
  countMode       LoyaltyCountMode @default(ALL_SERVICES)
  /// Validade do carimbo em dias (fidVal). null = nunca expira.
  stampTtlDays    Int?
  /// Programa pausado: enquanto != null, agendamentos depois desta data não contam
  /// carimbo e o cartão fica congelado. null = ativo.
  pausedAt        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  qualifyingServices LoyaltyProgramService[]
  redemptions        LoyaltyRedemption[]
}

enum LoyaltyPrizeKind {
  FREE_SERVICE
  DISCOUNT
}

enum LoyaltyCountMode {
  ALL_SERVICES
  SPECIFIC
}

/// Serviço que conta carimbo num programa com countMode = SPECIFIC (N:N).
model LoyaltyProgramService {
  id        String         @id @default(cuid())
  programId String
  program   LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([programId, serviceId])
  @@index([serviceId])
}

/// Resgate de um prêmio por um cliente (Contact). Marca o momento em que o cartão foi
/// zerado: carimbos passam a contar só a partir de `redeemedAt`. `stampsUsed` congela a
/// regra vigente no resgate (auditoria; a regra pode mudar depois).
model LoyaltyRedemption {
  id         String         @id @default(cuid())
  programId  String
  program    LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stampsUsed Int
  redeemedAt DateTime       @default(now())

  @@index([programId, contactId, redeemedAt])
  @@index([contactId])
}

/// Fila de espera: um cliente quer um DIA + PROFISSIONAL cuja agenda está cheia. Quando
/// um horário libera (cancelamento/remarcação), a engine (apps/web/src/lib/waitlist.ts)
/// notifica em ondas quem espera aquele par. A chave da fila é (tenantId, professionalId,
/// date); serviceId guarda o que o cliente queria (duração p/ recalcular horários + preço
/// p/ a métrica de receita recuperada). Ordem da fila = createdAt.
model WaitlistEntry {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User           @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// Dia desejado (data-calendário no fuso do tenant, sem hora).
  date           DateTime       @db.Date
  status         WaitlistStatus @default(WAITING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([tenantId, professionalId, date, contactId])
  @@index([tenantId, professionalId, date, status])
}

/// Episódio de match: criado quando um horário vaga e existe fila p/ (tenant, pro, dia).
/// Guarda o estado das ondas e serve de RESERVA temporária - enquanto ACTIVE e
/// holdExpiresAt > now, todos os horários livres desse profissional nesse dia ficam
/// congelados pro fluxo normal (ver isSlotFrozenByWaitlist). Não há tabela de hold por
/// slot: a reserva é derivada da existência deste offer.
model WaitlistOffer {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionalId   String
  professional     User                @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  /// Dia em que o horário vagou (mesma semântica de WaitlistEntry.date).
  date             DateTime            @db.Date
  /// Onda atual (1 = primeiros da fila). Cresce a cada avanço.
  wave             Int                 @default(1)
  /// Quando o cron deve avançar p/ a próxima onda (= último disparo + windowMinutes).
  nextWaveAt       DateTime
  /// Expiração da reserva temporária. Bump a cada onda; = now ao encerrar (libera o slot).
  holdExpiresAt    DateTime
  /// Ids de WaitlistEntry já notificados neste episódio (próxima onda = WAITING fora daqui).
  notifiedEntryIds String[]            @default([])
  status           WaitlistOfferStatus @default(ACTIVE)
  createdAt        DateTime            @default(now())

  @@index([status, nextWaveAt])
  @@index([tenantId, professionalId, date])
}

enum WaitlistStatus {
  WAITING
  FULFILLED
  CANCELED
}

enum WaitlistOfferStatus {
  ACTIVE
  FULFILLED
  EXHAUSTED
}

// --- Assinatura de serviços do cliente final (membership / "Clube") -----------
// NÃO confundir com Subscription (assinatura do DONO ao Demandaê). Aqui o DONO cria
// planos (MembershipPlan) e o CLIENTE FINAL assina (Membership), pagando mensalmente
// pelo gateway do PRÓPRIO tenant (Asaas /subscriptions nativo; o dinheiro cai na conta
// do dono). Créditos são consumidos ao agendar serviço coberto. Feature do plano Time+.

/// Plano de assinatura que o DONO oferece aos clientes dele (ex.: "Clube do Corte -
/// 4 cortes/mês, R$ 150"). É o catálogo/oferta; a assinatura de cada cliente é Membership.
model MembershipPlan {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  /// Preço mensal em centavos (cobrado recorrente no cartão do cliente).
  priceCents      Int
  interval        MembershipInterval @default(MONTHLY)
  /// Créditos concedidos a cada ciclo (ex.: 4 cortes/mês).
  creditsPerCycle Int
  /// true = créditos não usados acumulam pro próximo ciclo (até rolloverCap); false =
  /// vencem no fim do ciclo (aviso "créditos vencendo" alguns dias antes).
  creditRollover  Boolean            @default(false)
  /// Teto de créditos acumulados quando creditRollover=true. null = sem teto.
  rolloverCap     Int?
  /// false = plano pausado: para de VENDER novas assinaturas, mas quem já assina segue.
  active          Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  services    MembershipPlanService[]
  memberships Membership[]

  @@index([tenantId, active])
}

/// Serviços cobertos por um MembershipPlan (N:N) + custo em créditos de cada um.
model MembershipPlanService {
  id         String         @id @default(cuid())
  planId     String
  plan       MembershipPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  /// Quantos créditos um agendamento deste serviço consome (default 1).
  creditCost Int            @default(1)

  @@unique([planId, serviceId])
  @@index([serviceId])
}

/// Assinatura de UM cliente final a um MembershipPlan do tenant. Cobrança recorrente
/// mensal via /subscriptions nativo do gateway do tenant. Snapshot do plano na ativação
/// (grandfather: reprecificar o plano não muda quem já assina). Ciclo de vida é
/// webhook-driven (ver apps/web/src/lib/memberships/webhook-apply.ts).
model Membership {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId            String
  plan              MembershipPlan  @relation(fields: [planId], references: [id])
  /// Dono da assinatura (pagador/login). Cobrança recorrente no cartão exige conta -
  /// cliente só-telefone não assina.
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  /// Contact por-tenant resolvido no agendamento (pra descontar o crédito). Opcional:
  /// pode não existir ainda quando a assinatura é criada. SetNull preserva a assinatura.
  contactId         String?
  contact           Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  status MembershipStatus @default(PENDING)

  // Snapshot do plano na ativação (grandfather).
  planName        String
  priceCents      Int
  creditsPerCycle Int
  creditRollover  Boolean @default(false)
  rolloverCap     Int?

  // Ciclo vigente (definido/estendido pelo webhook a cada pagamento confirmado).
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  /// Saldo de créditos disponível AGORA. CACHE denormalizado do MembershipCreditLedger
  /// (= soma dos deltas não vencidos), mantido na MESMA transação de cada consumo/grant.
  /// É a GUARDA de concorrência: o consumo faz `UPDATE ... WHERE creditBalance > 0`
  /// atômico, impedindo gasto-duplo sob corrida (o advisory lock do insert é por
  /// profissional+horário, não serve pra isso). Ledger = auditoria; contador = guarda.
  creditBalance        Int       @default(0)
  /// Quando os créditos do ciclo vencem (= currentPeriodEnd se creditRollover=false;
  /// null se acumula). Alimenta o aviso "créditos vencendo".
  creditsExpireAt      DateTime?
  /// Dedup do aviso "créditos acabando": guarda o início do ciclo em que já avisamos,
  /// pra não repetir a cada consumo dentro do mesmo ciclo.
  lowCreditsNotifiedAt DateTime?

  // Recorrência no gateway do PRÓPRIO tenant (mesmo padrão da Subscription do dono).
  provider              PaymentProvider
  gatewayCustomerId     String?
  gatewaySubscriptionId String?         @unique
  cardLast4             String?
  cardBrand             String?

  canceledAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  charges      MembershipCharge[]
  ledger       MembershipCreditLedger[]
  appointments Appointment[]

  @@unique([planId, customerAccountId])
  @@index([tenantId, status])
  @@index([customerAccountId, status])
}

/// Recibo de UMA cobrança mensal recorrente da assinatura (análogo a Payment/Charge,
/// mas SEM Appointment). Criado pelo webhook a cada ciclo. @@unique(provider, externalId)
/// deduplica os múltiplos eventos que o gateway manda pro mesmo pagamento.
model MembershipCharge {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipId String
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  provider    PaymentProvider
  method      PaymentMethod   @default(CREDIT_CARD)
  status      PaymentStatus   @default(PENDING)
  /// Valor cobrado neste ciclo (snapshot).
  amountCents Int
  /// Janela do ciclo que esta cobrança paga.
  periodStart DateTime?
  periodEnd   DateTime?
  externalId  String?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  ledger MembershipCreditLedger[]

  @@unique([provider, externalId])
  @@index([membershipId])
  @@index([tenantId, status])
}

/// Ledger de créditos (fonte da verdade do saldo; Membership.creditBalance é o cache).
/// Uma linha por movimento: +grant no ciclo, -consumo ao agendar, +estorno no cancel,
/// -expiração no fim do ciclo sem rollover. Saldo = soma dos deltas não vencidos.
model MembershipCreditLedger {
  id            String                 @id @default(cuid())
  membershipId  String
  membership    Membership             @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  /// >0 concede crédito (grant/estorno), <0 consome (agendamento/expiração).
  delta         Int
  reason        MembershipLedgerReason
  /// Cobrança que originou o grant (reason=CYCLE_GRANT).
  chargeId      String?
  charge        MembershipCharge?      @relation(fields: [chargeId], references: [id], onDelete: SetNull)
  /// Agendamento que consumiu/estornou o crédito (reason=REDEEM/REVERSAL). SetNull
  /// preserva a trilha se o agendamento for apagado.
  appointmentId String?
  appointment   Appointment?           @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  /// Vencimento do crédito concedido (grant sem rollover = currentPeriodEnd). Consumos
  /// não vencem. Saldo disponível = soma dos deltas com expiresAt null ou > now.
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())

  /// Garante no máximo um débito e um estorno por agendamento (idempotência do consumo).
  @@unique([appointmentId, reason])
  @@index([membershipId, createdAt])
}

enum MembershipStatus {
  /// Criada, aguardando confirmação do 1º pagamento (checkout hospedado).
  PENDING
  /// Em dia; créditos ativos.
  ACTIVE
  /// Pagamento falhou; créditos suspensos (agenda cai pra avulso) até regularizar.
  PAST_DUE
  /// Cancelada pelo cliente (créditos válidos até currentPeriodEnd) ou encerrada.
  CANCELED
}

enum MembershipInterval {
  MONTHLY
}

enum MembershipLedgerReason {
  /// Créditos concedidos na ativação/renovação de um ciclo pago.
  CYCLE_GRANT
  /// Crédito consumido por um agendamento coberto.
  REDEEM
  /// Crédito devolvido (cancelamento/no-show de agendamento coberto dentro do ciclo).
  REVERSAL
  /// Créditos vencidos no fim do ciclo (plano sem rollover).
  EXPIRE
  /// Ajuste manual (suporte).
  ADJUST
}
