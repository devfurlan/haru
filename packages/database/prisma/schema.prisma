generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Domain models (esqueleto inicial - expandir conforme o produto evolui) ---

model Tenant {
  id       String @id @default(cuid())
  name     String
  slug     String @unique
  /// Fuso usado pra interpretar horários do estabelecimento (ex: "America/Sao_Paulo").
  timezone String @default("America/Sao_Paulo")

  /// URL pública da logo do estabelecimento (bucket tenant-assets). Imagem
  /// quadrada padronizada - usada na página pública e no painel.
  logoUrl       String?
  /// Endereço físico exibido pro cliente (texto livre, opcional).
  address       String?
  /// Coordenadas geocodificadas do `address` (via Nominatim/OSM ao salvar no painel).
  /// Alimentam a busca por proximidade no app. null = sem endereço ou não geocodificável.
  latitude      Float?
  longitude     Float?
  /// Descrição do negócio (perfil comercial do WhatsApp `description`, máx 256).
  description   String?
  /// Status/recado curto do WhatsApp (`about`, máx 139). Específico do perfil WhatsApp.
  whatsappAbout String?
  /// E-mail de contato exibido no perfil comercial do WhatsApp (`email`).
  email         String?

  /// Agendamento direto pela página pública (/[slug]). Quando false, a página só
  /// mostra serviços/horários e o botão de WhatsApp (sem formulário de booking).
  publicBookingEnabled      Boolean                   @default(true)
  /// Status com que um agendamento feito pela página pública entra: PENDING exige
  /// o dono confirmar no painel; CONFIRMED já reserva o horário na hora.
  publicBookingConfirmation PublicBookingConfirmation @default(PENDING)

  // WhatsApp Cloud API - credenciais por tenant (onboard via Embedded Signup).
  // O bot resolve qual tenant atende um webhook por whatsappPhoneNumberId.
  whatsappPhoneNumberId     String?   @unique
  whatsappBusinessAccountId String?
  /// Token de acesso do tenant (criptografar at rest em produção).
  whatsappAccessToken       String?
  /// Telefone E.164 do WhatsApp (sem +) usado em links públicos wa.me/...
  /// É diferente do whatsappPhoneNumberId (ID interno da Meta).
  whatsappDisplayPhone      String?
  /// Marca quando o número foi detectado como BANIDO pela Meta (status do phone
  /// number = BANNED). Enquanto setado, o loop de lembretes pula o tenant - a
  /// Meta recusa todo envio com erro genérico (#135000), então re-tentar só gera
  /// ruído. O alerta por e-mail é disparado uma única vez na transição p/ banido.
  /// Volta a null quando o número for reabilitado (limpar manualmente após appeal).
  whatsappBannedAt          DateTime?
  /// Última quality_rating conhecida do número na Meta (GREEN/YELLOW/RED). O loop
  /// de qualidade compara contra este valor e só alerta o operador quando piora
  /// (transição de rating), sem floodar a cada poll.
  whatsappQualityRating     String?

  /// URL opcional para POST quando agendamentos são criados/cancelados. Aceita
  /// webhooks de Discord, Slack, Zapier, n8n, etc. Para Discord: o body inclui
  /// um campo `content` com o resumo formatado.
  notificationWebhookUrl        String?
  /// Horas antes do horário marcado para o bot enviar lembrete via WhatsApp.
  /// 0 = lembretes desativados.
  reminderHoursBefore           Int     @default(24)
  /// Avisar o dono por e-mail quando um cliente pedir atendimento humano
  /// (handoff). O aviso no painel/realtime é sempre enviado; só o e-mail é opcional.
  handoffEmailEnabled           Boolean @default(true)
  /// Avisar o dono por e-mail dos eventos de agendamento: novo agendamento e quando
  /// o cliente cancela/remarca. NÃO inclui lembrete por agendamento (evita flood em
  /// agenda cheia). Controlado pelo dono em /settings; não afeta os e-mails do cliente.
  ownerAppointmentEmailsEnabled Boolean @default(true)
  /// Templates aprovados na Meta. Quando definidos, mensagens são enviadas via
  /// template em vez de freeform - escapam da regra das 24h. Todos esperam
  /// 3 variáveis no body: {{1}}=nome do cliente, {{2}}=data/hora formatada,
  /// {{3}}=nome do serviço.
  reminderTemplateName          String?
  reminderTemplateLanguage      String? @default("pt_BR")
  cancelTemplateName            String?
  cancelTemplateLanguage        String? @default("pt_BR")
  rescheduleTemplateName        String?
  rescheduleTemplateLanguage    String? @default("pt_BR")
  /// Template aprovado na Meta usado no convite de novos usuários da equipe.
  /// Quando definido, o convite é enviado via template (escapa a janela de 24h).
  /// Espera 2 variáveis no body: {{1}}=nome do estabelecimento, {{2}}=link de ativação.
  inviteTemplateName            String?
  inviteTemplateLanguage        String? @default("pt_BR")

  // --- Pagamentos -------------------------------------------------------------
  /// Gateway de pagamento ativo. null = pagamentos desativados (sem botão "Pagar"
  /// na página pública). Só a credencial do provider ativo é usada.
  paymentProvider PaymentProvider?
  /// Quando true, usa as URLs de sandbox do gateway (testes). false = produção.
  paymentSandbox  Boolean          @default(false)

  /// Credenciais criptografadas at rest (AES-256-GCM, formato "iv:tag:ct" em base64).
  /// Um campo por gateway - só o do provider ativo é preenchido por vez.
  paymentAsaasApiKeyEnc      String?
  paymentMercadoPagoTokenEnc String?
  paymentPagBankTokenEnc     String?
  paymentPagarmeApiKeyEnc    String?
  /// Token compartilhado validado no header do webhook do gateway (Asaas:
  /// "asaas-access-token"). Criptografado igual às credenciais.
  paymentWebhookTokenEnc     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  services           Service[]
  appointments       Appointment[]
  appointmentSeries  AppointmentSeries[]
  contacts           Contact[]
  conversations      Conversation[]
  scheduleBlocks     ScheduleBlock[]
  scheduleExceptions ScheduleException[]
  payments           Payment[]
  aiUsageLogs        AiUsageLog[]
  favorites          Favorite[]
  subscription       Subscription?
}

model User {
  id              String     @id @default(cuid())
  // Vinculado ao auth.users do Supabase
  authId          String     @unique
  email           String     @unique
  name            String?
  /// Telefone E.164 sem máscara (ex.: "5511912345678"). Destino do convite por
  /// WhatsApp. Opcional - OWNER criado no signup não tem telefone.
  phone           String?
  role            UserRole   @default(OWNER)
  /// Foto de perfil (bucket tenant-assets). Já redimensionada (quadrada, 128px webp);
  /// null = usa a inicial do nome como avatar. Trocar apaga o arquivo antigo.
  avatarUrl       String?
  /// Profissional = tem agenda própria (horários, serviços) e recebe agendamentos.
  /// false = usuário de apoio (recepcionista/secretária): acessa e gerencia as
  /// agendas dos outros, mas não tem agenda própria nem aparece no booking.
  /// O OWNER nasce profissional (caso solo). Conta no limite do plano por categoria.
  isProfessional  Boolean    @default(false)
  /// Ciclo de vida do acesso. Membro convidado nasce INVITED (sem senha) e vira
  /// ACTIVE quando define a senha pela tela de ativação.
  status          UserStatus @default(ACTIVE)
  /// Quando o convite foi enviado (membros INVITED). Null pra quem nasceu ACTIVE.
  invitedAt       DateTime?
  /// Quando o usuário ativou a conta (definiu a senha).
  activatedAt     DateTime?
  /// Prova de consentimento: quando o usuário aceitou os Termos/Privacidade no
  /// cadastro. Null para contas anteriores ao aceite obrigatório.
  termsAcceptedAt DateTime?
  /// Versão dos Termos aceita (ver TERMS_VERSION em apps/web/src/lib/legal.ts).
  termsVersion    String?
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  conversationReads    ConversationRead[]
  handoffConversations Conversation[]        @relation("ConversationHandoff")
  /// Agenda própria do profissional (vazia para recepcionistas).
  scheduleBlocks       ScheduleBlock[]
  scheduleExceptions   ScheduleException[]
  appointments         Appointment[]
  professionalServices ProfessionalService[]
}

enum UserRole {
  OWNER
  STAFF
}

enum UserStatus {
  /// Convidado pelo admin, ainda não definiu a senha.
  INVITED
  /// Conta ativa (definiu a senha / criada no signup).
  ACTIVE
}

/// Identidade GLOBAL do cliente final (quem agenda serviços), com login próprio.
/// Diferente de `User` (dono/staff): uma CustomerAccount é cross-tenant - enxerga os
/// agendamentos de TODOS os estabelecimentos onde o cliente agendou. Vinculada ao
/// auth.users do Supabase pelo authId (mesma tabela de auth dos donos, tabelas de
/// domínio distintas). O vínculo com os Contacts (um por tenant) é feito por
/// telefone - ver claimContactsByPhone em apps/web/src/lib/customer-claim.ts.
model CustomerAccount {
  id                       String    @id @default(cuid())
  /// Vinculado ao auth.users do Supabase (mesma origem que User.authId).
  authId                   String    @unique
  email                    String    @unique
  name                     String?
  /// Foto de perfil (bucket tenant-assets). Já redimensionada (quadrada, 128px);
  /// null = usa a inicial do nome como avatar. Trocar apaga o arquivo antigo.
  avatarUrl                String?
  /// Telefone E.164 sem máscara (ex.: "5511912345678") - SÓ recebe número já
  /// VERIFICADO por OTP. É o que reivindica (claim) os Contacts de mesmo telefone em
  /// todos os tenants. Opcional: a conta pode existir antes de confirmar o telefone.
  phone                    String?
  /// Telefone informado no cadastro mas AINDA NÃO verificado. Fica separado de
  /// `phone` pra nunca disparar o claim sem prova de posse; serve só pra pré-preencher
  /// a barra de confirmação pós-login. É limpo quando o número é confirmado.
  pendingPhone             String?
  /// Prova de consentimento (Termos/Privacidade) no cadastro do cliente.
  termsAcceptedAt          DateTime?
  /// Versão dos Termos aceita (ver TERMS_VERSION em apps/web/src/lib/legal.ts).
  termsVersion             String?
  /// Receber e-mails dos próprios agendamentos (confirmação, lembrete, remarcação,
  /// cancelamento). Controlado pelo cliente em /conta/perfil. Independente dos avisos
  /// por WhatsApp do estabelecimento.
  appointmentEmailsEnabled Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  contacts    Contact[]
  pushDevices PushDevice[]
  favorites   Favorite[]

  @@index([phone])
}

/// Estabelecimento favoritado por um cliente (cross-tenant). Só aparece no app do
/// cliente; um par (cliente, tenant) é único (favoritar de novo é idempotente).
model Favorite {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([customerAccountId, tenantId])
  @@index([customerAccountId])
  @@index([tenantId])
}

/// Dispositivo (app mobile) de um cliente para receber push (Expo Push). Um cliente
/// pode ter vários aparelhos. O token identifica o device na Expo; é substituível
/// (o app re-registra a cada login). Usado pelo loop de lembretes do bot.
model PushDevice {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  /// Expo push token (ex.: "ExponentPushToken[...]"). Único: um device = um token.
  expoPushToken     String          @unique
  /// "android" | "ios" (informativo).
  platform          String?
  createdAt         DateTime        @default(now())
  lastSeenAt        DateTime        @default(now())

  @@index([customerAccountId])
}

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  durationMinutes Int
  priceCents      Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments  Appointment[]
  /// Quais profissionais executam este serviço (N:N). Vazio = nenhum oferece.
  professionals ProfessionalService[]
}

/// Vínculo N:N entre um profissional (User) e um Service que ele executa. Define
/// quem pode ser agendado para cada serviço no booking público e no bot.
model ProfessionalService {
  id             String   @id @default(cuid())
  professionalId String
  professional   User     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([professionalId, serviceId])
  @@index([serviceId])
}

/// Janela de atendimento de um PROFISSIONAL em um dia da semana. Múltiplos blocos
/// no mesmo dia representam expediente partido (ex: 08:00-12:00 e 14:00-18:00).
/// Ausência de blocos para um weekday = profissional fechado naquele dia.
model ScheduleBlock {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Profissional dono desta grade (User com isProfessional=true).
  professionalId String
  professional   User     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  /// 0 = domingo, 6 = sábado (igual `Date#getDay()`).
  weekday        Int
  /// Minutos desde a meia-noite (ex: 480 = 08:00).
  startMinute    Int
  endMinute      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, professionalId, weekday])
}

/// Bloqueio pontual da agenda do Tenant: um intervalo [startsAt, endsAt) em UTC
/// onde não se aceita agendamento (folga, compromisso pessoal, férias).
/// "Dia inteiro" e "vários dias" são apenas intervalos maiores.
model ScheduleException {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Folga de um profissional específico. null = folga do estabelecimento inteiro
  /// (aplica a todos os profissionais).
  professionalId String?
  professional   User?    @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, startsAt])
}

model Contact {
  id                 String           @id @default(cuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone              String
  name               String?
  email              String?
  /// CPF/CNPJ do cliente, só dígitos (ex.: "12345678909"). Coletado no pagamento
  /// (o Asaas exige documento do pagador pra emitir Pix) e reusado em cobranças futuras.
  document           String?
  /// Data de nascimento. Guardada como meia-noite UTC; a parte de hora é ignorada.
  birthDate          DateTime?
  /// Marca quando o cliente confirmou o cadastro básico via bot. null = ainda não.
  /// É o sinal usado pelo gate de agendamento (NÃO confiar em `name`, que o profile do WhatsApp autopreenche).
  profileCompletedAt DateTime?
  /// Cliente pediu pra parar de receber lembretes por WhatsApp ("parar"/"sair").
  /// Enquanto setado, o loop de lembretes pula o envio WhatsApp deste contato (o
  /// e-mail tem opt-out próprio em CustomerAccount). Zerado só manualmente.
  remindersOptOutAt  DateTime?
  /// Conta global do cliente que reivindicou este Contact (por telefone). null =
  /// ainda não vinculado a um login. Um Contact pertence a um único tenant, mas
  /// vários Contacts (de tenants diferentes) podem apontar pra mesma CustomerAccount.
  /// onDelete: SetNull -> apagar a conta do cliente NÃO apaga o Contact (que é do tenant).
  customerAccountId  String?
  customerAccount    CustomerAccount? @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  conversations Conversation[]
  appointments  Appointment[]

  @@unique([tenantId, phone])
  @@index([customerAccountId])
  @@index([phone])
}

model Conversation {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId        String
  contact          Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// Handoff humano: enquanto > now(), o bot fica em silêncio nesta conversa e o
  /// dono responde manualmente pelo painel. null = bot ativo. Cada mensagem do
  /// cliente renova a janela (24h de inatividade); expira sozinho sem cron.
  handoffExpiresAt DateTime?
  /// Quem assumiu a conversa (atribuição "em atendimento por X"). null = bot ativo.
  handoffById      String?
  handoffBy        User?     @relation("ConversationHandoff", fields: [handoffById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  messages    Message[]
  reads       ConversationRead[]
  aiUsageLogs AiUsageLog[]
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  waMessageId    String?          @unique
  body           String
  createdAt      DateTime         @default(now())

  @@index([conversationId, direction, createdAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

/// Marca de leitura por usuário: cada usuário do tenant tem seu próprio estado
/// de "lida" por conversa. Conversa não-lida = existe Message INBOUND com
/// createdAt > lastReadAt (ou sem registro de leitura).
model ConversationRead {
  userId         String
  conversationId String
  lastReadAt     DateTime @default(now()) @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([conversationId])
}

model Appointment {
  id                  String             @id @default(cuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId           String
  contact             Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  serviceId           String
  service             Service            @relation(fields: [serviceId], references: [id])
  /// Profissional que atende este agendamento (User com isProfessional=true).
  professionalId      String
  professional        User               @relation(fields: [professionalId], references: [id])
  startsAt            DateTime
  endsAt              DateTime
  status              AppointmentStatus  @default(PENDING)
  /// Série de recorrência à qual essa ocorrência pertence. null = agendamento avulso.
  /// Ocorrências da mesma série compartilham serviço/contato e são geradas juntas.
  seriesId            String?
  series              AppointmentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  /// Marca de quando o lembrete via WhatsApp foi enviado. null = ainda não.
  reminderSentAt      DateTime?
  /// Marca de quando o lembrete por E-MAIL ao cliente foi processado. null = ainda
  /// não. Separado de `reminderSentAt` (WhatsApp) pra que os dois canais sejam
  /// independentes. Zerado junto na remarcação, pra disparar de novo no novo horário.
  reminderEmailSentAt DateTime?
  /// Marca de quando o lembrete via PUSH (app) foi enviado. null = ainda não. Mesmo
  /// padrão dos outros canais - evita reenvio a cada tick do loop; zerado na remarcação.
  reminderPushSentAt  DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments Payment[]

  @@index([tenantId, startsAt])
  @@index([professionalId, startsAt])
  @@index([seriesId])
}

/// Agrupa as ocorrências de um agendamento recorrente (semanal/quinzenal/mensal).
/// As ocorrências são expandidas em registros Appointment reais na criação - esta
/// tabela guarda só a regra (frequência), pra rotular a série e cancelá-la inteira.
model AppointmentSeries {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  frequency RecurrenceFrequency
  createdAt DateTime            @default(now())

  appointments Appointment[]

  @@index([tenantId])
}

/// Frequência de repetição de uma série de agendamentos.
enum RecurrenceFrequency {
  WEEKLY // toda semana (+7 dias)
  BIWEEKLY // quinzenal (+14 dias)
  MONTHLY // mensal (+1 mês, mesmo dia, com clamp ao último dia do mês)
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NO_SHOW
}

/// Status inicial de um agendamento feito pela página pública. Subconjunto de
/// AppointmentStatus (só os estados válidos na criação) - enum próprio pra impedir
/// gravar CANCELED/COMPLETED/NO_SHOW como default.
enum PublicBookingConfirmation {
  PENDING
  CONFIRMED
}

/// Cobrança de um agendamento via gateway de pagamento. Relação 1:N com Appointment
/// (re-tentativas geram registros novos preservando histórico); a "cobrança ativa" é
/// a PENDING mais recente não expirada. Pagamento é opcional e NÃO altera o status do
/// Appointment - confirmação de agenda e de pagamento são independentes.
model Payment {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  provider PaymentProvider
  method   PaymentMethod   @default(UNDEFINED)
  status   PaymentStatus   @default(PENDING)

  /// Snapshot do Service.priceCents no momento da cobrança - o preço do serviço pode
  /// mudar depois; a cobrança preserva o valor cobrado de fato.
  amountCents Int

  /// CPF/CNPJ do pagador (só dígitos) enviado ao gateway nesta cobrança. Snapshot -
  /// o `Contact.document` pode mudar; aqui fica o documento usado de fato na charge.
  payerDocument String?

  /// ID da cobrança no gateway (ex.: Asaas "pay_xxx"). Único por provider.
  externalId   String?
  /// URL do checkout/fatura hospedada (Asaas invoiceUrl) - usada pra cartão e fallback.
  checkoutUrl  String?
  /// Pix: imagem do QR em base64 (data URI) e o copia-e-cola (payload EMV).
  pixQrCode    String?
  pixCopyPaste String?
  /// Vencimento da cobrança (Pix expira). Decide reaproveitar ou recriar a cobrança.
  expiresAt    DateTime?
  paidAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, externalId])
  @@index([tenantId, status])
  @@index([appointmentId])
}

/// Gateways de pagamento suportados. Só ASAAS está implementado; os demais têm
/// adapter stub (UI selecionável, cobrança lança "ainda não disponível").
enum PaymentProvider {
  ASAAS
  MERCADO_PAGO
  PAGBANK
  PAGARME
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  EXPIRED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  /// Checkout que deixa o cliente escolher o meio (Asaas billingType UNDEFINED).
  UNDEFINED
}

/// Pré-cadastro de interesse vindo da landing (signup público está desativado).
model Lead {
  id           String   @id @default(cuid())
  name         String
  businessName String
  whatsapp     String
  email        String?
  message      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// Consumo de tokens da OpenAI por tenant. Uma linha por turno do bot
/// (já agregando todas as chamadas do loop de tool calls). Usada para
/// medir/ratear o custo de IA de cada estabelecimento.
model AiUsageLog {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Conversa que originou o consumo (drill-down). null se a conversa sumiu.
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  /// Modelo usado (ex: "gpt-5-mini").
  model String

  /// Total de tokens de input do turno (inclui os cacheados).
  inputTokens       Int
  /// Subconjunto de `inputTokens` servido do cache (cobrado com desconto).
  cachedInputTokens Int @default(0)
  /// Tokens de output (inclui os de reasoning).
  outputTokens      Int
  /// Tokens de reasoning (subconjunto de `outputTokens`), só pra visibilidade.
  reasoningTokens   Int @default(0)
  /// Soma reportada pela OpenAI (input + output).
  totalTokens       Int
  /// Quantas chamadas à OpenAI compuseram o turno (1 + tool hops).
  requests          Int @default(1)

  /// Custo estimado em USD, calculado na escrita com o preço vigente do modelo
  /// (congela o preço da época, imune a mudanças futuras de tabela).
  costUsd Decimal @db.Decimal(12, 6)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

// --- Billing / planos (assinatura do SaaS) -----------------------------------

/// Catálogo de planos editável (preço/limites/features mudam sem deploy). A
/// `Subscription` fotografa estes valores na ativação - mudar um Plan aqui só
/// afeta NOVOS assinantes e a página /precos; quem já assina mantém o snapshot.
model Plan {
  id   String   @id @default(cuid())
  tier PlanTier @unique
  name String

  /// Preços em centavos. priceAnnualCents = total do ciclo anual (já com desconto).
  priceMonthlyCents Int
  priceAnnualCents  Int

  /// Limites mensais. null = ilimitado (Enterprise).
  appointmentsPerMonth Int?
  aiMessagesPerMonth   Int?
  /// Máximo de profissionais (usuários com agenda própria). 1 = só o dono. null = ilimitado.
  maxProfessionals     Int?
  /// Máximo de recepcionistas (usuários de apoio, sem agenda). 0 = nenhum. null = ilimitado.
  maxReceptionists     Int?

  /// Features liberadas pelo tier.
  onlinePayments Boolean @default(false)
  webhooks       Boolean @default(false)
  team           Boolean @default(false)

  /// Disponível para contratação / visível na página de preços.
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Assinatura do SaaS de um Tenant (1:1). Guarda um SNAPSHOT dos termos do Plan
/// no momento da contratação - o gating lê daqui, não do Plan ao vivo, garantindo
/// que reprecificar um Plan não muda quem já assina (grandfather).
model Subscription {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planTier     PlanTier
  status       SubscriptionStatus @default(PENDING)
  billingCycle BillingCycle       @default(MONTHLY)

  /// Janela do ciclo atual de cobrança.
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  /// Prazo da garantia de satisfação (reembolso integral até esta data, ~30d).
  guaranteeUntil     DateTime?
  canceledAt         DateTime?

  // --- Snapshot dos termos contratados (copiado do Plan na ativação) ---
  /// Preço efetivamente contratado, em centavos, referente ao billingCycle.
  priceCents         Int
  appointmentsLimit  Int?
  aiMessagesLimit    Int?
  maxProfessionals   Int?
  maxReceptionists   Int?
  featOnlinePayments Boolean @default(false)
  featWebhooks       Boolean @default(false)
  featTeam           Boolean @default(false)

  // --- Asaas (recorrência - Fase 2) ---
  asaasCustomerId     String?
  asaasSubscriptionId String?
  /// Última cobrança do Asaas já contabilizada. Dedup de webhook: o Asaas manda
  /// CONFIRMED e RECEIVED para o mesmo pagamento - guardamos o id pra não enviar
  /// e-mail/recibo duplicado nem reprocessar.
  lastBilledPaymentId String?

  /// Quando a configuração assistida do WhatsApp (setup) foi contratada: no checkout
  /// (opt-in mensal), na ativação do WhatsApp, ou coberta pelo anual (grátis). null =
  /// ainda não contratada - a oferta aparece na ativação. Evita cobrar o setup 2x.
  setupChargedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum PlanTier {
  ESSENCIAL
  PROFISSIONAL
  NEGOCIO
  ENTERPRISE
}

enum SubscriptionStatus {
  /// Aguardando confirmação do primeiro pagamento (Fase 2).
  PENDING
  /// Assinatura em dia.
  ACTIVE
  /// Pagamento falhou; em carência (grace) ainda com acesso.
  PAST_DUE
  /// Carência esgotada ou cancelada; sem acesso (bot off, dashboard read-only).
  SUSPENDED
  /// Cancelada pelo cliente ao fim do ciclo.
  CANCELED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

// --- Suporte in-app (bot de IA que responde dúvidas e coleta feedback) --------
// Uma linha por mensagem (usuário ou assistente). O "histórico" de uma pessoa é o
// conjunto de linhas dela ordenado por createdAt - não há tabela de thread. Serve os
// dois apps: WEB (dono do negócio, via userId+tenantId) e MOBILE (cliente final, via
// customerAccountId). Quando a IA detecta crítica/sugestão, marca feedbackCategory e o
// servidor manda um e-mail; nada é respondido in-app pelo fundador.
// ponytail: FK solta (sem relation) pra migration mínima; virar relation quando
// precisar de join/cascade.
model SupportMessage {
  id      String         @id @default(cuid())
  channel SupportChannel
  role    SupportRole
  body    String

  /// WEB: User (dono/staff) que escreveu/recebeu. null no mobile.
  userId String?
  /// WEB: tenant do usuário logado (contexto do negócio). null no mobile.
  tenantId String?
  /// MOBILE: cliente final. null no web.
  customerAccountId String?

  /// Set só quando a mensagem do usuário foi classificada como feedback.
  feedbackCategory SupportCategory?
  /// MOBILE: quando o feedback é sobre um estabelecimento específico do cliente.
  aboutTenantId String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([customerAccountId, createdAt])
}

enum SupportChannel {
  WEB
  MOBILE
}

enum SupportRole {
  USER
  ASSISTANT
}

enum SupportCategory {
  DUVIDA
  CRITICA
  SUGESTAO
}
