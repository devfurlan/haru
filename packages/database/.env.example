# Copie para .env — scripts do Prisma (`generate`, `push`, `migrate`, `seed`) lêem via `dotenv -e .env`.
# Valores abaixo são os defaults do Supabase local rodando via `pnpm supabase:start` na raiz.

# Postgres local — em dev a conexão é direta, então DATABASE_URL e DIRECT_URL são iguais.
# DATABASE_URL = runtime (app via pg adapter). DIRECT_URL = `prisma migrate`/`db push`.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54362/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54362/postgres"

# Em produção (Supabase), use o padrão da doc — DUAS conexões:
#   DATABASE_URL = transaction pooler (porta 6543, ?pgbouncer=true)  → runtime do app
#   DIRECT_URL   = session pooler     (porta 5432)                   → migrations (suporta DDL/advisory lock)
# DATABASE_URL="postgresql://postgres.<ref>:[SENHA]@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<ref>:[SENHA]@<region>.pooler.supabase.com:5432/postgres"

# Supabase admin (usado pelo seed pra criar usuário de auth)
SUPABASE_URL="http://127.0.0.1:54361"
SUPABASE_SECRET_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"
