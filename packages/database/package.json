{
  "name": "@haru/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "dotenv -e .env -- prisma generate",
    "generate": "dotenv -e .env -- prisma generate",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
    "push": "dotenv -e .env -- prisma db push",
    "studio": "dotenv -e .env -- prisma studio",
    "seed": "dotenv -e .env -- tsx prisma/seed.ts",
    "seed:plans": "dotenv -e .env -- tsx scripts/seed-plans.ts",
    "set-plan": "dotenv -e .env -- tsx scripts/set-plan.ts",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@haru/typescript-config": "workspace:*",
    "@supabase/supabase-js": "^2.78.0",
    "@types/node": "^22.15.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
